# ============================================================
# HentaiBros Frontend — Environment Variables
# Copy ke .env.local untuk development lokal
# Set di Vercel Dashboard untuk production
# ============================================================

# URL publik website (untuk canonical, og:image, structured data)
REACT_APP_SITE_URL=https://your-domain.com

# Untuk development lokal: URL backend API kamu
# Di production, backend URL diset di vercel.json (server-side, tidak expose ke browser)
# REACT_APP_API_URL=http://localhost:5000
